# =============================================================================
# Distributed Task Queue - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# All values below are REQUIRED for production use.
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=taskqueue
DATABASE_URL=postgresql+asyncpg://postgres:changeme_in_production@localhost:5432/taskqueue

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
APP_VERSION=0.2.0
CORS_ORIGINS=["*"]

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Database Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Celery Timeouts
CELERY_SOFT_TIME_LIMIT=300
CELERY_TIME_LIMIT=600
CELERY_RESULT_EXPIRES=3600

# Worker Settings
HEARTBEAT_INTERVAL=30
STALE_WORKER_CLEANUP_INTERVAL=60
STUCK_JOB_RECOVERY_INTERVAL=120
STALE_WORKER_TIMEOUT=90
STUCK_JOB_TIMEOUT=600

# Circuit Breaker
CB_DEFAULT_FAILURE_THRESHOLD=5
CB_DEFAULT_RECOVERY_TIMEOUT=60

# Dead Letter Queue
DLQ_MAX_SIZE=1000
DLQ_TTL_SECONDS=604800

# Progress Tracking
PROGRESS_TTL_SECONDS=3600

# Retry Backoff
RETRY_BACKOFF_BASE=10
RETRY_BACKOFF_JITTER_MAX=30

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
